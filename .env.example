# Target environment: dev | qa | prod-us | prod-eu
# Most testing runs on dev (no 2FA). prod-us/prod-eu block mutations (prodGuard).
ENV=dev

# Base URLs of the admin Platform per environment.
# Confirm exact hostnames against sm2/config.js (ENV_PREFIX / BASE_URL).
BASE_URL_DEV=https://dev.platform.mediastre.am
BASE_URL_QA=https://qa.platform.mediastre.am
BASE_URL_PROD_US=https://platform.mediastre.am
BASE_URL_PROD_EU=https://eu.platform.mediastre.am

# Dedicated test account with admin permissions, PER ENVIRONMENT.
TEST_USER_DEV=
TEST_PASS_DEV=
TEST_USER_QA=
TEST_PASS_QA=
TEST_USER_PROD_US=
TEST_PASS_PROD_US=
TEST_USER_PROD_EU=
TEST_PASS_PROD_EU=

# Optional global fallback used when the per-env user/pass above is empty.
TEST_USER=
TEST_PASS=

# Second test user, PER ENVIRONMENT. Only used to test cross-session behavior
# (the "changed by another user" alert, sm2#8317) with two real, independent
# sessions. A normal user (no is_admin required). Empty -> those specs skip.
TEST_USER2_DEV=
TEST_PASS2_DEV=
TEST_USER2_QA=
TEST_PASS2_QA=

# --- Two-factor (TOTP) ---
# dev has no 2FA, leave TOTP_SECRET_DEV empty.
# qa/prod accounts: KEEP 2FA ENABLED. When you set up the authenticator app, the QR screen also
# shows a base32 "secret" (or "setup key") — paste THAT here, per environment. The suite generates
# the 6-digit code at login (src/utils/totp.js), so the account is never left with 2FA disabled
# (which would auto-lock after a week). Never commit real secrets.
TOTP_SECRET_DEV=
TOTP_SECRET_QA=
TOTP_SECRET_PROD_US=
TOTP_SECRET_PROD_EU=

# API token for data setup/teardown (Settings > API in the dashboard).
# If empty, the API layer falls back to the session JWT obtained at login.
API_TOKEN=

# --- Token Profiles module gate (sm2#8451, media.category) ---
# The Settings > API token form only shows the "Profile" dropdown to a session user
# with is_admin=true (views/settings/api.coffee) — the QA bot account never sees it,
# so it cannot self-service create a token WITH a profile. However the server route
# (POST /api/account/token) does NOT gate the `profile` field by is_admin, only by
# ACCOUNT_ADMIN_ACCESS + the account module `api_tokens` — so once that module is
# enabled for this account, AQ2 CAN create/delete its own tokens per test (self-
# contained fixture) and assign an EXISTING TokenProfile id directly via API,
# bypassing the UI limitation. What still requires a one-time platform-admin (is_admin)
# setup: creating the TokenProfile documents themselves.
# Ask an admin, once, for:
#   1. The `api_tokens` module enabled on this account.
#   2. Two TokenProfile ids: one whose `modules` includes 'media.category', one that
#      does not (e.g. an empty list or an unrelated module).
# See knowledge-core/modules/token-profiles for the full permission map.
TOKEN_PROFILE_ID_WITH_CATEGORY_DEV=
TOKEN_PROFILE_ID_WITHOUT_CATEGORY_DEV=

# Video público corto y liviano para ingesta remota (fixture transcodedMedia).
# Default reproducible en el código; override aquí si el default deja de servir.
QA_SAMPLE_VIDEO_URL=

# --- AI QA pipeline (the /qa command) ---
# SM2 source repo for diff analysis and PR fetching (used by gh CLI).
SM2_GITHUB_REPO=mediastream/sm2
# Local clone of SM2 — agents read views/routes/swagger from here when populating qa-knowledge.
SM2_LOCAL_REPO=D:/Dev/Repos/mediastream/sm2
# GitHub repo where QA issues are created (usually this QA repo).
QA_GITHUB_REPO=jurrego1771/qa-platform
# Slack Incoming Webhook for QA reports. If empty, Slack notifications are skipped.
SLACK_WEBHOOK=
# Optional: a prior QA-knowledge repo to seed module docs faster (token-saver). Leave empty to
# author purely from the SM2 source + industry research. The pipeline never hard-depends on this.
PRIOR_KNOWLEDGE_REPO=
